# Copy this file to .env and fill in real values.
# PostgreSQL credentials (read by docker-compose.yml)
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=appdb

# Host port to expose Postgres on (maps to container's 5432)
POSTGRES_PORT=5432

# Host the Go app connects to (the app runs on your machine -> localhost)
DB_HOST=localhost

# TLS mode for the DB connection. Local loopback -> disable.
# In production (RDS / remote DB) use require or verify-full.
DB_SSLMODE=disable
